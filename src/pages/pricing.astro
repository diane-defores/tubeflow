---
import Layout from '../layouts/Layout.astro'
import Navbar from '../components/Navbar.astro'
import Newsletter from '../components/Newsletter.astro'
import Footer from '../components/Footer.astro'

const plans = [
  {
    name: 'Free', price: '0',
    description: 'Perfect for getting started with video notes',
    features: ['Up to 10 videos', 'Unlimited notes per video', 'Basic search', 'Mobile access', 'Export to Markdown'],
    cta: 'Get Started', href: 'https://tubeflow.app/videos', popular: false,
  },
  {
    name: 'Pro', price: '9',
    description: 'For serious learners and professionals',
    features: ['Unlimited videos', 'Unlimited notes', 'Advanced search & filters', 'Priority support', 'Export to PDF & Markdown', 'Custom playlists', 'AI-powered summaries', 'Team sharing (coming soon)'],
    cta: 'Start Free Trial', href: 'https://tubeflow.app/videos', popular: true,
  },
]

const faqs = [
  { q: 'Can I try Pro features before subscribing?', a: 'Yes! All new accounts get a 14-day free trial of Pro features. No credit card required.' },
  { q: 'What happens to my notes if I downgrade?', a: 'Your notes are always yours. If you downgrade, you keep all existing notes but can only add new notes to your 10 most recent videos.' },
  { q: 'Can I cancel anytime?', a: "Absolutely. Cancel your subscription anytime from your account settings. You'll keep Pro access until the end of your billing period." },
  { q: 'Do you offer team or education pricing?', a: 'Yes! Contact us for special pricing for teams, educational institutions, and non-profits.' },
]

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Product",
    name: "TubeFlow Pro",
    description: "Unlimited video notes, advanced search, and AI-powered summaries",
    offers: { "@type": "Offer", price: "9", priceCurrency: "USD", availability: "https://schema.org/InStock" },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((f) => ({
      "@type": "Question", name: f.q,
      acceptedAnswer: { "@type": "Answer", text: f.a },
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: "https://tubeflow.app/" },
      { "@type": "ListItem", position: 2, name: "Pricing", item: "https://tubeflow.app/pricing" },
    ],
  },
]
---

<Layout
  title="Pricing - TubeFlow"
  description="Simple, transparent pricing for TubeFlow. Start free, upgrade when you need more."
  path="/pricing"
  jsonLd={jsonLd}
>
  <main id="main-content" class="min-h-screen bg-background text-foreground">
    <Navbar />

    <!-- Hero -->
    <section class="max-w-5xl mx-auto px-4 pt-32 pb-16 text-center">
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-foreground" style="font-family: var(--font-cal-sans);">
        Simple, transparent pricing
      </h1>
      <p class="mt-4 text-lg text-muted-foreground">Start free. Upgrade when you need more power.</p>
    </section>

    <!-- Pricing Cards -->
    <section class="max-w-4xl mx-auto px-4 pb-16">
      <div class="grid gap-8 md:grid-cols-2">
        {plans.map((plan) => (
          <div class={`relative rounded-2xl border ${plan.popular ? 'border-foreground/30 shadow-lg' : 'border-border'} bg-card p-8`}>
            {plan.popular && (
              <div class="absolute -top-3 left-1/2 -translate-x-1/2">
                <span class="rounded-full bg-foreground px-4 py-1 text-sm font-medium text-background">Most Popular</span>
              </div>
            )}
            <div class="text-center mb-6">
              <h2 class="text-2xl font-bold text-foreground">{plan.name}</h2>
              <p class="mt-2 text-muted-foreground">{plan.description}</p>
              <div class="mt-6">
                <span class="text-5xl font-bold text-foreground">${plan.price}</span>
                {plan.price !== '0' && <span class="text-muted-foreground">/month</span>}
              </div>
            </div>
            <ul class="space-y-4 mb-8">
              {plan.features.map((feature) => (
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 shrink-0 text-emerald-500 mt-0.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg>
                  <span class="text-foreground">{feature}</span>
                </li>
              ))}
            </ul>
            <a
              href={plan.href}
              class={`block w-full text-center rounded-full py-3 text-sm font-medium transition-colors ${
                plan.popular
                  ? 'shimmer-btn bg-white text-zinc-950 hover:bg-zinc-200'
                  : 'bg-card text-foreground hover:bg-muted border border-border'
              }`}
            >
              {plan.cta}
            </a>
          </div>
        ))}
      </div>
      <p class="mt-8 text-center text-muted-foreground">
        Want to know exactly what you get? <a href="/features" class="text-foreground underline underline-offset-4 hover:opacity-80">See all features in detail</a>
      </p>
    </section>

    <!-- FAQ -->
    <section class="bg-card py-16 sm:py-24">
      <div class="max-w-3xl mx-auto px-4">
        <h2 class="text-center text-3xl font-bold text-foreground mb-12" style="font-family: var(--font-instrument-sans);">Frequently Asked Questions</h2>
        <div class="space-y-8">
          {faqs.map((faq) => (
            <div>
              <h3 class="text-lg font-semibold text-foreground">{faq.q}</h3>
              <p class="mt-2 text-muted-foreground">{faq.a}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="max-w-3xl mx-auto px-4 py-16 sm:py-24 text-center">
      <h2 class="text-3xl font-bold text-foreground mb-4">Ready to start learning smarter?</h2>
      <p class="text-lg text-muted-foreground mb-8">Join thousands of learners who use TubeFlow every day.</p>
      <a href="https://tubeflow.app/videos" class="shimmer-btn inline-flex items-center bg-white text-zinc-950 hover:bg-zinc-200 rounded-full px-8 py-3 text-base font-medium transition-colors">Get Started Free</a>
    </section>

    <Newsletter />
    <Footer />
  </main>
</Layout>
