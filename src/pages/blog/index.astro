---
import Layout from '../../layouts/Layout.astro'
import Navbar from '../../components/Navbar.astro'
import Footer from '../../components/Footer.astro'
import { getCollection } from 'astro:content'

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
)

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Blog",
    name: "TubeFlow Blog",
    description: "Tips, guides, and insights for better video-based learning and note-taking.",
    url: "https://tubeflow.app/blog",
    publisher: {
      "@type": "Organization",
      name: "TubeFlow",
      logo: { "@type": "ImageObject", url: "https://tubeflow.app/icon-512.png" },
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: "https://tubeflow.app/" },
      { "@type": "ListItem", position: 2, name: "Blog", item: "https://tubeflow.app/blog" },
    ],
  },
]
---

<Layout
  title="Blog - TubeFlow"
  description="Tips and strategies for video-based learning"
  path="/blog"
  jsonLd={jsonLd}
>
  <main class="min-h-screen bg-background text-foreground">
    <Navbar />

    <section class="max-w-4xl mx-auto px-4 pt-32 pb-16">
      <div class="text-center mb-12">
        <h1 class="text-4xl sm:text-5xl font-bold text-foreground mb-4" style="font-family: var(--font-cal-sans);">
          From Our Blog
        </h1>
        <p class="text-lg text-muted-foreground">Tips and strategies for video-based learning</p>
      </div>

      <div class="grid gap-6">
        {posts.map((post) => (
          <a
            href={`/blog/${post.id}`}
            class="group block rounded-2xl border border-border bg-card p-6 transition-all duration-300 hover:border-foreground/25 hover:scale-[1.01]"
          >
            <div class="flex items-center gap-2 text-xs text-muted-foreground mb-3">
              <svg class="w-3 h-3" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
              <time datetime={post.data.date}>
                {new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </time>
              {post.data.tags && post.data.tags.length > 0 && (
                <>
                  <span class="text-border">·</span>
                  {post.data.tags.slice(0, 3).map((tag) => (
                    <span class="px-2 py-0.5 rounded-full bg-muted text-muted-foreground text-xs">{tag}</span>
                  ))}
                </>
              )}
            </div>
            <h2 class="text-xl font-semibold text-foreground group-hover:text-foreground/80 transition-colors mb-2">
              {post.data.title}
            </h2>
            <p class="text-muted-foreground text-sm line-clamp-2">{post.data.description}</p>
            <span class="mt-4 inline-flex items-center gap-1 text-sm text-foreground font-medium">
              Read more
              <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>
    </section>

    <Footer />
  </main>
</Layout>
