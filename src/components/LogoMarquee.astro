---
const logos = ['YouTube', 'Coursera', 'Udemy', 'Notion', 'Obsidian', 'Markdown', 'Vimeo', 'Twitch']
---

<section class="py-16 overflow-hidden bg-background" data-reveal>
  <div class="text-center mb-10">
    <p class="text-sm text-muted-foreground uppercase tracking-wider font-medium">Works with the platforms you already use</p>
  </div>

  <div class="relative">
    <!-- Fade masks -->
    <div class="absolute left-0 top-0 bottom-0 w-32 bg-gradient-to-r from-background to-transparent z-10 pointer-events-none"></div>
    <div class="absolute right-0 top-0 bottom-0 w-32 bg-gradient-to-l from-background to-transparent z-10 pointer-events-none"></div>

    <!-- Marquee -->
    <div class="flex animate-marquee">
      {[...logos, ...logos].map((name) => (
        <div class="flex items-center justify-center min-w-[160px] h-16 mx-8 grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-300">
          <div class="flex items-center gap-2 text-muted-foreground">
            <div class="w-8 h-8 rounded-lg bg-card border border-border flex items-center justify-center">
              <span class="text-xs font-bold">{name[0]}</span>
            </div>
            <span class="font-medium" style="font-family: var(--font-instrument-sans);">{name}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
