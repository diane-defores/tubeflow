          <p class="text-muted-foreground text-sm mb-4">Edge-optimized infrastructure for sub-50ms response times globally.</p>
          <div class="flex items-center gap-2 text-emerald-500 text-sm">
            <span class="font-mono">~32ms</span>
            <span class="text-muted-foreground">avg response</span>
          </div>
        </div>
      </div>

      <!-- Enterprise Security -->
      <div class="group relative p-6 rounded-2xl bg-card border border-border hover:border-foreground/25 hover:scale-[1.02] transition-all duration-300" data-reveal>
        <div class="animate-fade-up delay-400">
          <div class="p-2 rounded-lg bg-muted w-fit mb-4">
            <svg class="w-5 h-5 text-muted-foreground" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-foreground mb-2">Enterprise Security</h3>
          <p class="text-muted-foreground text-sm mb-4">SOC2 compliant with end-to-end encryption and SSO support.</p>
          <div class="flex items-center gap-2">
            <span class="px-2 py-1 text-xs bg-muted rounded text-muted-foreground">SOC2</span>
            <span class="px-2 py-1 text-xs bg-muted rounded text-muted-foreground">GDPR</span>
            <span class="px-2 py-1 text-xs bg-muted rounded text-muted-foreground">HIPAA</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // System status dots flickering
  const statusDots = document.querySelectorAll('#system-status span')
  setInterval(() => {
    statusDots.forEach((dot) => {
      const active = Math.random() > 0.2
      dot.classList.toggle('bg-emerald-500', active)
      dot.classList.toggle('bg-zinc-700', !active)
    })
  }, 2000)

  // Keyboard ⌘K press animation
  const keys = document.querySelectorAll<HTMLElement>('.kbd-key')
  setInterval(() => {
    keys.forEach((key, i) => {
      setTimeout(() => {
        key.style.transform = 'scale(0.95) translateY(2px)'
        setTimeout(() => {
          key.style.transform = ''
        }, 200)
      }, i * 50)
    })
  }, 3000)
</script>
