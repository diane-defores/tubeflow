      </div>

      <!-- Command Palette -->
      <div class="group relative p-6 rounded-2xl bg-card border border-border hover:border-foreground/25 hover:scale-[1.02] transition-all duration-300" data-reveal>
        <div class="animate-fade-up delay-100">
          <div class="p-2 rounded-lg bg-muted w-fit mb-4">
            <svg class="w-5 h-5 text-muted-foreground" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 6v12a3 3 0 1 0 3-3H6a3 3 0 1 0 3 3V6a3 3 0 1 0-3 3h12a3 3 0 1 0-3-3"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-foreground mb-2">Command Palette</h3>
