---
import Layout from '../layouts/Layout.astro'
import Navbar from '../components/Navbar.astro'
import Newsletter from '../components/Newsletter.astro'
import Footer from '../components/Footer.astro'
import { appUrl, siteUrl } from '../config/site'

const features = [
  { title: 'Timestamped Notes', desc: 'Capture thoughts at the exact moment they happen. Click any note to jump back to that point in the video instantly.', icon: '🕐' },
  { title: 'Universal Video Support', desc: 'Works with YouTube, Vimeo, and most video URLs. Paste any link and start taking notes immediately.', icon: '🎬' },
  { title: 'Organized Playlists', desc: 'Group related videos into playlists. Perfect for online courses, research projects, or topic deep-dives.', icon: '📂' },
  { title: 'Instant Search', desc: 'Find any note across all your videos in seconds. Your entire video library becomes searchable.', icon: '🔍' },
  { title: 'Real-Time Sync', desc: 'Your notes sync instantly across all your devices. Start on your laptop, continue on your phone.', icon: '⚡' },
  { title: 'Private & Secure', desc: 'Your notes are yours alone. We use industry-standard encryption to keep your data safe.', icon: '🔒' },
  { title: 'Mobile Friendly', desc: 'Full-featured mobile experience. Take notes on the go, wherever you\'re learning.', icon: '📱' },
  { title: 'Export Anywhere', desc: 'Export your notes to Markdown, PDF, or plain text. Your knowledge is never locked in.', icon: '📖' },
]

const steps = [
  { num: 1, title: 'Paste a Video URL', desc: 'Drop any YouTube, Vimeo, or video link into ReplayGlowz.' },
  { num: 2, title: 'Take Notes as You Watch', desc: 'Click to add notes. Each one is linked to that moment in the video.' },
  { num: 3, title: 'Review & Learn', desc: 'Click any note to jump back. Search across all your videos.' },
]

const jsonLd = [{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: siteUrl('/') },
    { "@type": "ListItem", position: 2, name: "Features", item: siteUrl('/features') },
  ],
}]
---

<Layout
  title="Features - ReplayGlowz"
  description="Discover ReplayGlowz's powerful features for video note-taking: timestamped notes, video playlists, instant search, and more."
  path="/features"
  jsonLd={jsonLd}
>
  <main id="main-content" class="min-h-screen bg-background text-foreground">
    <Navbar />

    <!-- Hero -->
    <section class="max-w-5xl mx-auto px-4 pt-32 pb-16 text-center">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-foreground" style="font-family: var(--font-cal-sans);">
        Everything you need to learn from video
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-muted-foreground">
        ReplayGlowz combines powerful note-taking with seamless video playback. Stop losing insights. Start building knowledge.
      </p>
      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href={appUrl('/videos')} class="shimmer-btn inline-flex items-center bg-white text-zinc-950 hover:bg-zinc-200 rounded-full px-6 py-3 text-sm font-medium transition-colors">Get Started Free</a>
        <a href="/pricing" class="inline-flex items-center rounded-full px-6 py-3 text-sm font-medium border border-border text-muted-foreground hover:bg-card hover:text-foreground transition-colors">View Pricing</a>
      </div>
    </section>

    <!-- Features Grid -->
    <section class="bg-card py-16 sm:py-24">
      <div class="max-w-6xl mx-auto px-4">
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
          {features.map((f) => (
            <div class="rounded-xl border border-border bg-background p-6">
              <div class="mb-4 text-3xl">{f.icon}</div>
              <h3 class="mb-2 text-lg font-semibold text-foreground">{f.title}</h3>
              <p class="text-sm text-muted-foreground">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section class="max-w-5xl mx-auto px-4 py-16 sm:py-24">
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl font-bold text-foreground" style="font-family: var(--font-instrument-sans);">How It Works</h2>
        <p class="mt-4 text-lg text-muted-foreground">Three simple steps to better video learning</p>
      </div>
      <div class="grid gap-8 md:grid-cols-3">
        {steps.map((s) => (
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-foreground text-xl font-bold text-background">{s.num}</div>
            <h3 class="mb-2 text-lg font-semibold text-foreground">{s.title}</h3>
            <p class="text-muted-foreground">{s.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-card py-16 sm:py-24">
      <div class="max-w-3xl mx-auto px-4 text-center">
        <h2 class="text-3xl font-bold text-foreground mb-4">Ready to transform how you learn?</h2>
        <p class="text-lg text-muted-foreground mb-8">Join thousands of learners who use ReplayGlowz to capture insights from video.</p>
        <a href={appUrl('/videos')} class="shimmer-btn inline-flex items-center bg-white text-zinc-950 hover:bg-zinc-200 rounded-full px-8 py-3 text-base font-medium transition-colors">Start Free Today</a>
      </div>
    </section>

    <Newsletter />
    <Footer />
  </main>
</Layout>
