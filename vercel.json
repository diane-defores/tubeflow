{
  "buildCommand": "flutter/bin/flutter build web --dart-define=CONVEX_URL=${NEXT_PUBLIC_CONVEX_URL:-$CONVEX_URL} --dart-define=CLERK_PUBLISHABLE_KEY=${NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY:-$CLERK_PUBLISHABLE_KEY}",
  "outputDirectory": "build/web",
  "installCommand": "git clone --depth 1 -b stable https://github.com/flutter/flutter.git flutter && flutter/bin/flutter pub get",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
