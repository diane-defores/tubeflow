# Convex deployment URL
CONVEX_URL=https://your-deployment.convex.cloud

# Clerk publishable key (from Clerk dashboard)
CLERK_PUBLISHABLE_KEY=pk_test_...

# Clerk secret key (required by the Vercel YouTube OAuth callback)
CLERK_SECRET_KEY=sk_live_...

# Google OAuth client credentials for YouTube connection
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...

# TubeFlow web app origin used for YouTube OAuth handoff and callback URLs
TUBEFLOW_APP_URL=https://app.tubeflow.winflowz.com
