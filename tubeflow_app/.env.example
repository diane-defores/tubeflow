# Safe placeholders only. Do not put real secrets in committed example files.

# Build-time Flutter web configuration
CONVEX_URL=https://your-deployment.convex.cloud
CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
TUBEFLOW_APP_URL=https://app.example.com
# Optional hosted Clerk sign-in override. Defaults to TUBEFLOW_APP_URL when omitted.
CLERK_HOSTED_SIGN_IN_URL=
# Optional build metadata surfaced in diagnostics.
BUILD_COMMIT_SHA=local
BUILD_ENVIRONMENT=local
BUILD_TIMESTAMP=2026-05-10T00:00:00Z

# Server-side secrets for Vercel OAuth callback handling
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Compatibility fallbacks still accepted by build.sh / OAuth handlers.
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
TUBEFLOW_WEB_URL=
