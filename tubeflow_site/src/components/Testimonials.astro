---
const testimonials = [
  {
    rating: 5,
    review: 'Great note-taking application! The AI features make note-taking a breeze.',
    name: 'Ryan Lowry',
    designation: 'Engineer & Author',
    featured: false,
  },
  {
    rating: 5,
    review: "Really like the clean design of TubeFlow. The AI-driven search is impressively accurate, adding a personal dimension to my notes. Fast and very easy to use.",
    name: 'John Collins',
    designation: 'Engineer & Author',
    featured: true,
  },
  {
    rating: 5,
    review: 'Simply brilliant! TubeFlow has elevated my productivity.',
    name: 'Moe Partuj',
    designation: 'Student',
    featured: false,
  },
]
---

<section id="reviews" class="py-16 sm:py-24 bg-card">
  <div class="max-w-6xl mx-auto px-4">
    <div class="text-center mb-12 sm:mb-16" data-reveal>
      <p class="animate-fade-up text-sm font-medium text-muted-foreground uppercase tracking-wider mb-2">Reviews</p>
      <h2
        class="animate-fade-up delay-100 text-3xl sm:text-4xl font-bold text-foreground"
        style="font-family: var(--font-instrument-sans);"
      >
        User Testimonials
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4" data-reveal>
      {testimonials.map((item, index) => (
        <div
          class={`animate-fade-up delay-${(index + 1) * 100} relative p-6 rounded-2xl border transition-all duration-300 hover:scale-[1.02] ${
            item.featured
              ? 'bg-background border-border'
              : 'bg-background/50 border-border hover:border-foreground/25'
          }`}
        >
          {item.featured && (
            <div class="absolute inset-0 rounded-2xl overflow-hidden pointer-events-none">
              <div
                class="absolute w-24 h-24 bg-white/20 blur-xl border-beam"
                style="offset-path: rect(0 100% 100% 0 round 16px);"
              ></div>
            </div>
          )}

          <!-- Stars -->
          <div class="flex gap-1 mb-4" role="img" aria-label={`${item.rating} out of 5 stars`}>
            {Array.from({ length: item.rating }).map(() => (
              <svg class="w-4 h-4 fill-amber-400 text-amber-400" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            ))}
          </div>

          <blockquote class="text-foreground mb-6 leading-relaxed">
            &ldquo;{item.review}&rdquo;
          </blockquote>

          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full border border-border bg-gradient-to-br from-foreground/20 to-foreground/5 flex items-center justify-center text-xs font-medium text-foreground/60">
              {item.name[0]}
            </div>
            <div>
              <p class="font-medium text-foreground text-sm">{item.name}</p>
              <p class="text-xs text-muted-foreground">{item.designation}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
