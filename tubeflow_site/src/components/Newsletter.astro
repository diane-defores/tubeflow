<section class="py-16 sm:py-24 bg-background">
  <div class="max-w-2xl mx-auto px-4 text-center" data-reveal>
    <h2 class="animate-fade-up text-2xl sm:text-3xl font-bold text-foreground mb-4" style="font-family: var(--font-instrument-sans);">
      Stay in the Loop
    </h2>
    <p class="animate-fade-up delay-100 text-muted-foreground mb-8">
      Get the latest ReplayGlowz updates, tips, and productivity insights delivered to your inbox.
    </p>

    <form class="animate-fade-up delay-200 flex flex-col sm:flex-row gap-3 max-w-md mx-auto" id="newsletter-form" novalidate>
      <label for="newsletter-email" class="sr-only">Email address</label>
      <input
        id="newsletter-email"
        type="email"
        placeholder="Enter your email"
        required
        autocomplete="email"
        aria-describedby="newsletter-status"
        class="flex-1 px-4 py-3 rounded-full bg-card border border-border text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-foreground/20 text-sm"
      />
      <button
        type="submit"
        class="shimmer-btn bg-white text-zinc-950 hover:bg-zinc-200 rounded-full px-6 py-3 text-sm font-medium transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
      >
        Subscribe
      </button>
    </form>

    <p id="newsletter-status" role="status" aria-live="polite" class="animate-fade-up delay-300 mt-4 text-xs text-muted-foreground">No spam, unsubscribe anytime.</p>

    <script>
      const form = document.getElementById('newsletter-form') as HTMLFormElement
      const status = document.getElementById('newsletter-status') as HTMLParagraphElement
      const input = document.getElementById('newsletter-email') as HTMLInputElement
      const btn = form?.querySelector('button[type="submit"]') as HTMLButtonElement

      form?.addEventListener('submit', async (e) => {
        e.preventDefault()
        if (!input.value || !input.validity.valid) {
          status.textContent = 'Please enter a valid email address.'
          status.className = 'mt-4 text-xs text-red-400'
          input.focus()
          return
        }
        btn.disabled = true
        btn.textContent = 'Subscribing…'
        status.textContent = ''
        status.className = 'mt-4 text-xs text-muted-foreground'

        // Simulate submission — replace with real endpoint
        await new Promise((r) => setTimeout(r, 800))

        form.reset()
        btn.disabled = false
        btn.textContent = 'Subscribe'
        status.textContent = "You're in! We'll be in touch soon."
        status.className = 'mt-4 text-xs text-emerald-400'
      })
    </script>
  </div>
</section>
